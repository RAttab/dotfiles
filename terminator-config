[global_config]
  focus = system
  window_state = maximise
  inactive_color_offset = 1.0
  enabled_plugins = APTURLHandler,
[keybindings]
  broadcast_off = <Shift><Super>b
  broadcast_group = <Super>b
  broadcast_all = None
  layout_launcher = <Primary><Alt>l
[profiles]
  [[default]]
    audible_bell = True
    font = Bitstream Vera Sans Mono 10
    scrollback_lines = 500000
    copy_on_selection = True
[layouts]
  [[default]]
    [[[child1]]]
      type = Terminal
      parent = window0
    [[[window0]]]
      type = Window
      parent = ""
[plugins]
